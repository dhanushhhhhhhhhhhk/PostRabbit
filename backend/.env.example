# PostRabbit Backend — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/postrabbit

# OpenRouter API key for LLM summarization
OPENROUTER_API_KEY=

# Whisper API key for speech-to-text transcription
WHISPER_API_KEY=

# Enable debug mode (true / false)
DEBUG=false
